# ============================================
# Cloudflare API 配置（用于本地开发和迁移）
# ============================================

# Cloudflare Account ID（在 Dashboard 首页右侧）
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare API Token
# 需要权限：D1 Edit, R2 Edit, KV Edit, Pages Edit
CLOUDFLARE_API_TOKEN=your_api_token_here

# ============================================
# D1 数据库配置
# ============================================

# D1 数据库 ID
D1_DATABASE_ID=your_d1_database_id_here

# ============================================
# R2 对象存储配置
# ============================================

# R2 桶名称
BUCKET_NAME=your_r2_bucket_name_here

# ============================================
# KV 缓存配置
# ============================================

# KV 命名空间 ID
KV_NAMESPACE_ID=your_kv_namespace_id_here

# ============================================
# 站点配置
# ============================================

# 站点 URL
SITE_URL=https://your-blog-domain.com

# 环境
NODE_ENV=development
